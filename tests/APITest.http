@host = http://localhost:8080
@auth = admin:admin
@base = {{host}}/index.php/apps/thelab

###
# ─── SANITY CHECKS ────────────────────────────────────────────────────────────

### 1. Nextcloud is alive
GET {{host}}

### 2. Auth works
GET {{host}}/ocs/v1.php/cloud/user
Authorization: Basic {{auth}}
OCS-APIRequest: true

###
# ─── INIT ─────────────────────────────────────────────────────────────────────

### 3. Create theLAB folder
POST {{base}}/api/init
Authorization: Basic {{auth}}
Content-Type: application/json
Content-Length: 0

###
# ─── FILES ────────────────────────────────────────────────────────────────────

### 4. List theLAB root
GET {{base}}/api/files?path=theLAB
Authorization: Basic {{auth}}

### 5. List a subfolder (edit path to match a real folder)
GET {{base}}/api/files?path=theLAB/projects
Authorization: Basic {{auth}}

###
# ─── SHARES ───────────────────────────────────────────────────────────────────

### 6. List all shares
GET {{base}}/api/shares
Authorization: Basic {{auth}}

### 7. Create a share — minimal (path only)
POST {{base}}/api/shares
Authorization: Basic {{auth}}
Content-Type: application/json

{
  "path": "theLAB/projects"
}

### 8. Create a share — with password and expiry
POST {{base}}/api/shares
Authorization: Basic {{auth}}
Content-Type: application/json

{
  "path": "theLAB/my-project",
  "password": "secret123",
  "expiryDate": "2026-12-31",
  "hideDownload": true
}

### 9. Delete a share (paste the id from the response above)
DELETE {{base}}/api/shares/ocinternal:42
Authorization: Basic {{auth}}

###
# ─── METADATA ─────────────────────────────────────────────────────────────────

### 10. Get metadata
GET {{base}}/api/metadata?path=theLAB/my-project/track.wav
Authorization: Basic {{auth}}

### 11. Update metadata
POST {{base}}/api/metadata
Authorization: Basic {{auth}}
Content-Type: application/json

{
  "path": "theLAB/my-project/track.wav",
  "title": "My Track",
  "artist": "Me",
  "bpm": "120"
}

###
# ─── SHARES ─────────────────────────────────────────────────────────────────

### Verify Share link
GET {{base}}/apps/thelab/s/Cgnmifay8Lw8TXt

### Should return folder contents with no auth
GET http://localhost:8080/index.php/apps/thelab/api/share/nZTGHNRj3k8cWfq/files


### Stream file via share token — no auth header
GET http://localhost:8080/index.php/apps/thelab/api/share/Cgnmifay8Lw8TXt/stream