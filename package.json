    "axios": "^1.13.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vue": "^3.5.30",
    "wavesurfer.js": "^7.12.3"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
