{
  "name": "theLAB",
  "description": "A nextcloud app for sharing/managing projects",
  "version": "1.0.0",
  "author": "Alex Little",
  "contributors": [],
  "bugs": {
    "url": "https://github.com/alexloggedin/the-lab/issues"
  },
  "repository": {
    "url": "git+https://github.com/alexloggedin/the-lab.git",
    "type": "git"
  },
  "homepage": "https://github.com/alexloggedin/the-lab",
  "license": "agpl",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:docker": "VITE_USE_MOCK=false vite",
    "build": "vite build && npm run copy-dist",
    "copy-dist": "cp dist/thelab.js js/thelab.js && cp dist/thelab.css css/thelab.css",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue src --fix",
    "stylelint": "stylelint css/*.css css/*.scss src/**/*.scss src/**/*.vue",
    "stylelint:fix": "stylelint css/*.css css/*.scss src/**/*.scss src/**/*.vue --fix"
  },
  "dependencies": {
    "@nextcloud/axios": "^2.3.0",
    "@nextcloud/dialogs": "^3.2.0",
    "@nextcloud/router": "^2.1.1",
    "@nextcloud/vue": "^9.6.0",
    "axios": "^1.13.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vue": "^3.5.30",
    "wavesurfer.js": "^7.12.3"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.3.0"
  },
  "devDependencies": {
    "@nextcloud/browserslist-config": "^2.3.0",
    "@nextcloud/eslint-config": "^8.2.1",
    "@nextcloud/stylelint-config": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0"
  },
  "main": ".eslintrc.js",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "keywords": []
}